[package]
name = arcgis_updates
title = ArcGIS Enterprise Patch Update Check
author = Ryan Macias / Turret Consulting
description = Discovers ArcGIS Enterprise components from the Windows registry
    (HKLM\SOFTWARE\ESRI) and compares installed patch QFE_IDs against Esri's
    patch notification feed. Emits one CheckMK local check service per
    discovered component. Supports ArcGIS Server, Portal, Data Store, and any
    other Esri product that uses the QFEPatchFinder / QFEARP registry markers.
    Windows only. Configurable feed URL supports internal patch mirrors.

version = 1.0.0
version.min_required = 2.3.0p1
version.packaged = 2.5.0p3
version.usable_until = None

download_url = https://github.com/turretsec/cmk-arcgis-updates